# Database Configuration
# PostgreSQL connection string (e.g., from Neon, Supabase, or Railway)
DATABASE_URL="postgresql://username:password@host.region.provider.tech/database_name?sslmode=require"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"

# Application URL
# Use http://localhost:3000 for local development
# Use your production domain for deployment
NEXTAUTH_URL="http://localhost:3000"
